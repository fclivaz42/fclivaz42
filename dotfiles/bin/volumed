#!/bin/bash

# Volume handler script.

if [[ -z $1 ]] || [[ -z $2 ]]; then
	echo "Usage: volumed < -i | -d | -t > <volume>"
	exit 1
fi

! [[ "$2" =~ ^[0-9]+$ ]] && echo "<volume> must be an integer." && exit 1

[[ "$2" -gt 100 ]] && echo "<volume> must be between 0 and 100." && exit 1

if [[ $(eww get volset) == "false" ]]; then
	eww open volpopup
	eww update volset=true
fi

case "$1" in
	"-i" | "-d")
		[ $(pamixer --get-mute) == 'true' ] && exit 1;
	;;
esac

pamixer "$1" "$2"

VOL="$(pamixer --get-volume)"

[ $(pamixer --get-mute) == 'true' ] && VOL="0"

eww update vol="$VOL"

pgrep -f "volumed" | grep -v "^$$\$" | xargs kill

PLAY=0

case "$1" in
	"-i" | "-d")
		(( "$VOL" % 10 )) || PLAY=1
	;;
	"-t")
		[[ $(pamixer --get-mute) == 'false' ]] && PLAY=1
	;;
esac

# [ $PLAY == 1 ] && ffplay -nodisp -volume 30 /usr/share/sounds/freedesktop/stereo/bell.oga -autoexit &

sleep 2
eww close volpopup
eww update volset=false
exit 0
