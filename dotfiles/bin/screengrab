#!/bin/bash

# Screenshot script.

if [[ -z $1 ]] || [[ -z $2 ]] || [[ -z $3 ]]; then
	echo "Usage: screengrab <snip | monitor | all> <tempdir> <finaldir> (edit)"
	exit 1
fi

DATE="$(date '+%Y-%m-%d_%H:%M:%S')"
NAMEFORMAT="Screenshot-$DATE.png"
MONITOR="$(hyprctl -j activeworkspace | jq -r .monitor)"
OUTFOLDER=""
DELAY=750
CONVERT=(magick -)
GRIM=(grim -t png -l 0)
SIZE=""

wl-copy -c

case $1 in
	"snip")
		SIZE="$(slurp)"
		GRIM+=(-g - -)
		OUTFOLDER="Snippets"
		NOTI="Snippet"
	;;
	"monitor")
		GRIM+=(-o $MONITOR -)
		OUTFOLDER="$MONITOR"
		NOTI="$MONITOR"
		sleep 0.5 && notify-send -a Screenshot "$OUTFOLDER" -t "$DELAY" &
	;;
	"all")
		GRIM+=(-)
		OUTFOLDER="Fullscreen"
		NOTI="$OUTFOLDER"
		sleep 0.5 && notify-send -a Screenshot "$OUTFOLDER" -t "$DELAY" &
	;;
	*)
		echo "Usage: screengrab <snip | monitor | all> <tempdir> <finaldir> (edit)"
		exit 1
	;;
esac

if [[ "$4" == "edit" ]]; then
	CONVERT+=(-)
	SWAP=(swappy -f - -o -)
else
	CONVERT+=(-quality 50 -)
	SWAP=(cat)
fi

mkdir -p "$3/$OUTFOLDER"

echo "$SIZE" | ${GRIM[@]} | ${CONVERT[@]} | ${SWAP[@]} | tee "$2/$NAMEFORMAT" | wl-copy

if [ -n "$(find "$2/$NAMEFORMAT" -prune -size +10c)" ]; then
	notify-send -a Screenshot "$NOTI copied to clipboard." -t "$DELAY"
	zopflipng -m -y "$2/$NAMEFORMAT" "$3/$OUTFOLDER/$NAMEFORMAT"
else
	notify-send -a Screenshot "$NOTI aborted." -t "$DELAY"
	rm "$2/$NAMEFORMAT"
	wl-copy -c
fi
