{
	// CPU
	"cpu": {
		"format": "/ п‹›  {usage}% ",
		"on-double-click": "kitty btop"
	},

	// Memory
	"memory": {
		"format": "/ о‰¦  {}% ",
		"on-double-click": "kitty btop"
	},

	// SSD space used
	"disk": {
		"interval": 60,
		"format": "/ п‡Ђ  {percentage_used}% ",
		"path": "/",
		"on-double-click": "kitty btop"
	}, 
	
	// Network
	"network": {
		"format": "{ifname}",
		"format-wifi": "/ п‡«  {signalStrength}% ",
		"format-ethernet": "/ пћ–  ",
		"format-disconnected": "/ п„§  ", //An empty format will hide the module.
		"tooltip-format": "пћ–  {ifname} via {gwaddri}",
		"tooltip-format-wifi": "п‡«  {essid} ({signalStrength}%)",
		"tooltip-format-ethernet": "пѓЃ  {ifname} ({ipaddr}/{cidr})",
		"tooltip-format-disconnected": "Disconnected",
		"on-double-click": "nm-connection-editor",
		"on-click-right": "if ifconfig wlan0 | grep 'UP' >/dev/null; then doas ifconfig wlan0 down && notify-send -a wlan0 down; else doas ifconfig wlan0 up && notify-send -a wlan0 up; fi",
		"max-length": 50,
		"interval": 5
	},

	// Battery
	"battery": {
		"states": {
			// "good": 95,
			"warning": 20,
			"critical": 10
		},
		"format": "/ {icon} {capacity}%",
		"format-charging": "/ п‡¦ {capacity}%",
		"format-plugged": "/ п‡¦ {capacity}%",
		"format-alt": "{icon} {time}",
		// "format-good": "", // An empty format will hide the module
		// "format-full": "",
		"interval": 5,
		"format-icons": ["п‰„ !", "п‰ѓ ", "п‰‚ ", "п‰Ѓ ", "п‰Ђ "]
	},

	// Pulseaudio
	"pulseaudio": {
		"scroll-step": 2, // %, can be a float
		"format": "{icon}{volume}% ",
		"format-muted": "пљ© 0% ",
		"format-icons": {
			"default": ["пЂ¦ ", "пЂ§ ", "пЂЁ  "]
		},
		"on-click-right": "pavucontrol",
		"on-click": "pamixer -t"
	},

	// Bluetooth
	"bluetooth": {
		"format": "",
		"format-disabled": "/ пЉ”у°Ѓ… ",
		"format-off": "/ пЉ”п‘§ ",
		"format-on": "/ пЉ”у°‡™ ",
		"format-connected": "/ пЉ”у°№№ ",
		"interval": 5,
		"on-click": "blueman-manager",
		"on-click-right": "if bt-adapter -i | grep 'Powered: 0' >/dev/null; then bt-adapter --set Powered 1; else bt-adapter --set Powered 0; fi"
	}
}
